# Copy this file to .env and fill in your Claude API key
# Get your key from: https://console.anthropic.com/
#
# DESKTOP (Electron): .env is read at runtime via dotenv.
# WEB (Vercel): do NOT commit .env. Instead set ANTHROPIC_API_KEY
#               in the Vercel dashboard (Project Settings > Environment Variables).
ANTHROPIC_API_KEY=sk-ant-your-key-here
