# Copy this file to .env and fill in your API key(s)
#
# DESKTOP (Electron): .env is read at runtime via dotenv.
# WEB (Vercel): do NOT commit .env. Instead set env vars
#               in the Vercel dashboard (Project Settings > Environment Variables).
#
# CATATAN: file ini HANYA untuk API key AI (Claude/Gemini).
# Kredensial LOGIN/Supabase TIDAK di sini — isinya di src/js/config.js
# (anon key Supabase aman bersifat publik). Lihat README + supabase-setup.sql.

# AI provider selection — "claude" (default) or "gemini" (free tier)
AI_PROVIDER=claude

# Anthropic Claude — paid. Get key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini — free tier (1500 req/day). Get key at https://aistudio.google.com
GEMINI_API_KEY=your-gemini-key-here
# Optional: override Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# PROTEKSI ENDPOINT AI (WEB / Vercel) — wajib untuk produk berbayar publik.
# Endpoint /api/ai/feedback sekarang MEWAJIBKAN login + menerapkan kuota bulanan
# per user (lihat supabase-ai-quota.sql). Set nilai ini di Vercel, BUKAN di sini.
#
#   SUPABASE_URL              = Project URL (sama dengan src/js/config.js)
#   SUPABASE_ANON_KEY         = anon public key (sama dengan config.js, aman publik)
#   SUPABASE_SERVICE_ROLE_KEY = service_role key — RAHASIA, server-only, JANGAN
#                               pernah taruh di config.js / kode browser / commit
#   AI_MONTHLY_LIMIT          = batas scoring AI per user/bulan (default 60)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
AI_MONTHLY_LIMIT=60

# Kunci fitur AI hanya untuk user berbayar. Biarkan "false" selama pengembangan
# (supaya kamu bisa tes AI tanpa membuat lisensi). Set "true" saat launch.
REQUIRE_PAID_LICENSE=false

# -----------------------------------------------------------------------------
# PEMBAYARAN (Midtrans) — diisi saat Fase 3 (sandbox dulu, lalu production).
# Ambil di dashboard Midtrans > Settings > Access Keys.
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxx
# "true" = sandbox (testing), "false" = production (uang asli).
MIDTRANS_IS_SANDBOX=true
# Harga akses (Rupiah), mis. 99000. Dipakai server saat membuat transaksi.
PRICE_IDR=99000
